    {
      "mitigation_number": 5,
      "mitigation_name": "Implement a strict outbound protocol whitelist on the FortiGate firewall to block raw ICMP from general hosts while permitting only required application protocols (HTTP/S, DNS, management) so splunkd HTTP checks continue to function",
      "tool_calls": [
        {
          "operation": "send_command",
          "args": {
            "device_identifier": "FortiGate7.0.14-1",
            "command": "show system interface"
          }
        },
        {
          "operation": "send_command",
          "args": {
            "device_identifier": "FortiGate7.0.14-1",
            "command": "show firewall policy"
          }
        },
        {
          "operation": "send_command",
          "args": {
            "device_identifier": "FortiGate7.0.14-1",
            "command": "config firewall service custom\nedit \"TCP-8443\"\n    set tcp-portrange 8443\nnext\nend"
          }
        },
        {
          "operation": "send_command",
          "args": {
            "device_identifier": "FortiGate7.0.14-1",
            "command": "config firewall service custom\nedit \"Allow-HTTP-HTTPS-DNS\"\n    set tcp-portrange 80-443\n    set udp-portrange 53\nnext\nend"
          }
        },
        {
          "operation": "send_command",
          "args": {
            "device_identifier": "FortiGate7.0.14-1",
            "command": "config firewall policy\nedit 2\n    set name \"LAN-to-WAN-Whitelist\"\n    set srcintf \"port2\"\n    set dstintf \"port1\"\n    set action accept\n    set srcaddr \"all\"\n    set dstaddr \"all\"\n    set schedule \"always\"\n    set service \"Allow-HTTP-HTTPS-DNS\"\n    set nat enable\nnext\nend"
          }
        },
        {
          "operation": "send_command",
          "args": {
            "device_identifier": "FortiGate7.0.14-1",
            "command": "config firewall policy\nedit 3\n    set name \"LAN-to-WAN-Deny-Other\"\n    set srcintf \"port2\"\n    set dstintf \"port1\"\n    set action deny\n    set srcaddr \"all\"\n    set dstaddr \"all\"\n    set schedule \"always\"\n    set service \"ALL\"\nnext\nend"
          }
        },
        {
          "operation": "send_command",
          "args": {
            "device_identifier": "FortiGate7.0.14-1",
            "command": "show firewall policy | grep -n \"LAN-to-WAN\" -n"
          }
        },
        {
